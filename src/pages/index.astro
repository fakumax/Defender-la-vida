---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import HeroCarousel from '~/components/common/HeroCarousel.astro';
import foto1 from '~/data/1.jpg';
import slide01 from '~/data/Widescreen/1.jpg';
import slide02 from '~/data/Widescreen/2.jpg';
import slide03 from '~/data/Widescreen/3.jpg';
import slide04 from '~/data/Widescreen/4.jpg';
import slide05 from '~/data/Widescreen/5.jpg';
import slide06 from '~/data/Widescreen/6.jpg';
import slide07 from '~/data/Widescreen/7.jpg';
import slide08 from '~/data/Widescreen/8.jpg';
import slide09 from '~/data/Widescreen/9.jpg';
import slide10 from '~/data/Widescreen/10.jpg';
import slide11 from '~/data/Widescreen/11.jpg';
import slide12 from '~/data/Widescreen/12.jpg';

const slides = [
  { image: slide01.src, alt: 'Defender la Vida' },
  { image: slide02.src, alt: 'Defender la Vida' },
  { image: slide03.src, alt: 'Defender la Vida' },
  { image: slide04.src, alt: 'Defender la Vida' },
  { image: slide05.src, alt: 'Defender la Vida' },
  { image: slide06.src, alt: 'Defender la Vida' },
  { image: slide07.src, alt: 'Defender la Vida' },
  { image: slide08.src, alt: 'Defender la Vida' },
  { image: slide09.src, alt: 'Defender la Vida' },
  { image: slide10.src, alt: 'Defender la Vida' },
  { image: slide11.src, alt: 'Defender la Vida' },
  { image: slide12.src, alt: 'Defender la Vida' },
];

const metadata = {
  title: 'Hablemos de Defender la Vida — Prevención del suicidio en Posadas, Misiones',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero ******************* -->
  <Hero
    actions={[
      { variant: 'primary', text: 'Pedir ayuda', href: '/contacto', icon: 'tabler:heart-handshake' },
      { text: 'Conocé nuestro trabajo', href: '/quienes-somos' },
    ]}
  >
    <Fragment slot="title">
      Hablemos de <span class="text-accent dark:text-white">Defender la Vida</span>
    </Fragment>

    <Fragment slot="subtitle">
      Asociación Civil de voluntarios dedicada a la <strong>prevención, orientación y posvención</strong> del suicidio.
      Acompañamos a personas en situación de riesgo, a sus familias y a quienes atravesaron la pérdida de un ser querido.
    </Fragment>

    <Fragment slot="content">
      <div class="flex justify-center mt-4 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
        <a href="tel:+543765481000" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-red-600 text-white font-semibold text-sm hover:bg-red-700 transition shadow">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
          ¿Estás en crisis? Llamá al 3765 481000 (24 hs)
        </a>
      </div>
    </Fragment>

    <Fragment slot="image">
      <HeroCarousel slides={slides} autoplay={6000} />
    </Fragment>
  </Hero>

  <!-- Nota ******************* -->
  <Note title="Nuestra misión:" description="Prevenir el suicidio y promover una cultura de cuidado colectivo." />

  <!-- Quiénes somos — resumen ******************* -->
  <Content
    id="quienes-somos"
    tagline="Quiénes somos"
    title="Una asociación que nació para cuidar la vida"
    items={[
      {
        title: 'Prevención',
        description: 'Trabajamos con escuelas, familias y comunidades para detectar signos de alerta a tiempo.',
        icon: 'tabler:shield-heart',
      },
      {
        title: 'Contención',
        description: 'Acompañamos a jóvenes en situación de riesgo y a su entorno familiar y social.',
        icon: 'tabler:users',
      },
      {
        title: 'Posvención',
        description: 'Brindamos apoyo a familias y comunidades que atravesaron la pérdida de un ser querido.',
        icon: 'tabler:heart-handshake',
      },
    ]}
    image={{
      src: foto1,
      alt: 'Hablar del dolor también es cuidar la vida — Defender la Vida',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        "Defender la Vida" nace en Posadas, Misiones
      </h3>
      <p>
        En 2004, con el firme propósito de prevenir el suicidio en la comunidad. Creemos que la prevención
        es posible y eficaz cuando nos involucramos todos: familia, escuela, trabajo y comunidad.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Qué hacemos — features ******************* -->
  <Features
    id="que-hacemos"
    tagline="Qué hacemos"
    title="Nuestros pilares de trabajo"
    subtitle="Intervenciones integrales para transformar actitudes violentas mediante la convivencia, la resolución de conflictos y el respeto mutuo."
    items={[
      {
        title: 'Talleres de prevención',
        description: 'Actividades en escuelas, clubes y organizaciones de Posadas y la provincia.',
        icon: 'tabler:presentation',
      },
      {
        title: 'Orientación',
        description: 'Espacio de escucha y derivación para jóvenes, familias y docentes.',
        icon: 'tabler:message-circle',
      },
      {
        title: 'Capacitaciones',
        description: 'Formación para equipos de salud, educación y comunidades.',
        icon: 'tabler:school',
      },
      {
        title: 'Campañas de concientización',
        description: 'Promovemos el diálogo y el cuidado de la salud mental en toda la región.',
        icon: 'tabler:speakerphone',
      },
      {
        title: 'Red de acompañamiento',
        description: 'Articulación con instituciones públicas, privadas y de la sociedad civil.',
        icon: 'tabler:network',
      },
    ]}
  />

  <!-- Estadísticas ******************* -->
  <Stats
    title="20+ años defendiendo la vida"
    subtitle="Desde Posadas, Misiones, para toda la región."
    stats={[
      { title: 'Años de trabajo', amount: '20+' },
      { title: 'Talleres anuales', amount: '50+' },
      { title: 'Jóvenes alcanzados', amount: '5k+' },
      { title: 'Familias acompañadas', amount: '500+' },
    ]}
  />

  <!-- Call to action ******************* -->
  <CallToAction
    actions={[
      { variant: 'primary', text: 'Contactanos', href: '/contacto', icon: 'tabler:mail' },
      { text: 'Ayuda en Misiones', href: '/contacto#ayuda', icon: 'tabler:phone-call' },
    ]}
  >
    <Fragment slot="title">¿Necesitás hablar con alguien?</Fragment>
    <Fragment slot="subtitle">
      No estás solo/a. Si estás en Misiones, llamá a <strong>3764 518800</strong> o <strong>3765 481000</strong>.
      También podés usar la línea nacional <strong>135</strong>.
    </Fragment>
  </CallToAction>
</Layout>
