---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import Hero from '~/components/widgets/Hero.astro';
import foto4 from '~/data/4.jpg';
import foto6 from '~/data/6.jpg';
import foto55 from '~/data/55.jpg';
import Content from '~/components/widgets/Content.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Quiénes somos',
};
---

<Layout metadata={metadata}>
  <!-- Hero ******************* -->
  <Hero
    tagline="Quiénes somos"
    image={{
      src: foto55,
      alt: 'Taller Hablemos de lo que sentimos — Defender la Vida',
    }}
  >
    <Fragment slot="title">
      Asociación Civil <br />
      <span class="text-accent dark:text-white">"Hablemos de Defender la Vida"</span>
    </Fragment>

    <Fragment slot="subtitle">
      Somos una ONG sin fines de lucro conformada por <strong>voluntarios</strong> de diversos sectores de la comunidad.
      Nacimos en Posadas, Misiones, con el propósito de prevenir el suicidio y acompañar a las personas en
      situación de crisis. Trabajamos de manera integral a través de la <strong>prevención, contención y posvención</strong>,
      acompañando tanto a quienes atraviesan situaciones de riesgo como a su entorno familiar y social.
    </Fragment>
  </Hero>

  <!-- Nuestra historia ******************* -->
  <Content
    isReversed
    tagline="Nuestra historia"
    title="Una asociación nacida del compromiso comunitario"
    items={[
      {
        title: 'Inicios en 2004',
        description: 'Comenzamos a trabajar en la ciudad de Posadas, provincia de Misiones, Argentina.',
        icon: 'tabler:flag',
      },
      {
        title: 'Personería Jurídica desde 2005',
        description: 'Obtuvimos la Personería Jurídica Nº A-2839 el 8 de junio de 2005.',
        icon: 'tabler:certificate',
      },
      {
        title: 'Interés provincial y municipal',
        description: 'Declarada de interés provincial (2010) y de interés municipal de Posadas (2012).',
        icon: 'tabler:award',
      },
    ]}
    image={{
      src: foto4,
      alt: 'Presentación institucional de Defender la Vida',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Más de dos décadas defendiendo la vida
      </h3>
      <p>
        Desde nuestros inicios sostenemos un trabajo comunitario con instituciones educativas, familias,
        equipos de salud, fuerzas de seguridad y organizaciones de la sociedad civil, articulando saberes
        técnicos con presencia humana, empatía y compromiso.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Misión y Visión ******************* -->
  <section class="px-4 py-12 sm:px-6 mx-auto lg:px-8 max-w-5xl">
    <div class="grid gap-6 md:grid-cols-2">
      <div class="rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-900 p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <Icon name="tabler:target-arrow" class="w-7 h-7 text-primary" />
          <h3 class="text-xl font-bold dark:text-white">Nuestra misión</h3>
        </div>
        <p class="text-gray-700 dark:text-slate-300">
          La prevención, orientación y posvención del suicidio en nuestra comunidad.
        </p>
      </div>
      <div class="rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-900 p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <Icon name="tabler:eye-heart" class="w-7 h-7 text-primary" />
          <h3 class="text-xl font-bold dark:text-white">Nuestra visión</h3>
        </div>
        <p class="text-gray-700 dark:text-slate-300">
          Defender la vida ante situaciones de crisis que puedan derivar en suicidio.
        </p>
      </div>
    </div>
  </section>

  <!-- Por qué trabajamos así ******************* -->
  <Content
    title="Por qué trabajamos así"
    items={[
      {
        title: 'El entorno importa',
        description:
          'Entendemos que el desarrollo de la personalidad es un proceso influenciado por el entorno. Por eso, nuestras intervenciones buscan transformar actitudes violentas.',
      },
      {
        title: 'Convivencia y respeto',
        description:
          'Promovemos la convivencia, la resolución pacífica de conflictos y el respeto mutuo como pilares de la salud mental colectiva.',
      },
      {
        title: 'Todos somos parte',
        description:
          'Estamos convencidos de que la prevención es posible y eficaz cuando nos involucramos todos: familia, escuela, trabajo y comunidad.',
      },
      {
        title: 'Tejido social fuerte',
        description:
          'Buscamos crear contextos positivos que fortalezcan nuestro tejido social y protejan a los más vulnerables.',
      },
    ]}
    image={{
      src: foto6,
      alt: 'Día Mundial de la Salud Mental — Defender la Vida',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Nuestra mirada</h3>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Valores ******************* -->
  <!-- Estadísticas ******************* -->
  <Stats
    title="Nuestro alcance"
    stats={[
      { title: 'Años', amount: '20+' },
      { title: 'Talleres', amount: '50+' },
      { title: 'Jóvenes', amount: '5k+' },
      { title: 'Familias', amount: '500+' },
    ]}
  />

  <!-- Marco legal ******************* -->
  <section class="px-4 py-12 sm:px-6 mx-auto lg:px-8 max-w-5xl">
    <div class="text-center mb-8">
      <h2 class="text-2xl md:text-3xl font-bold font-heading dark:text-white">Marco legal de referencia</h2>
      <p class="text-muted mt-2">Nuestro trabajo se enmarca en la normativa nacional y provincial vigente.</p>
    </div>
    <ul class="grid gap-4 sm:grid-cols-2">
      {[
        { ley: 'Ley 25.855', nombre: 'Voluntariado Social', desc: 'Define al voluntario como quien realiza tareas gratuitas, altruistas y de interés general por libre elección.' },
        { ley: 'Ley 27.130', nombre: 'Prevención del Suicidio (Nacional)', desc: 'Busca disminuir la incidencia del suicidio mediante prevención, asistencia y posvención.' },
        { ley: 'Ley XVII – Nº 103', nombre: 'Adhesión de Misiones', desc: 'Adhesión provincial a la ley nacional y creación del Centro de Asistencia a Personas en Riesgo de Suicidio.' },
        { ley: 'Ley 26.657', nombre: 'Salud Mental (Nacional)', desc: 'Reconoce la salud mental como un derecho humano y prioriza la atención comunitaria e interdisciplinaria.' },
      ].map(({ ley, nombre, desc }) => (
        <li class="flex gap-4 p-5 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-900">
          <Icon name="tabler:gavel" class="w-6 h-6 text-primary flex-shrink-0 mt-1" />
          <div>
            <p class="font-semibold text-gray-900 dark:text-slate-100">{ley} · {nombre}</p>
            <p class="text-sm text-gray-600 dark:text-slate-400 mt-1">{desc}</p>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <!-- Datos institucionales ******************* -->
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 max-w-4xl">
    <div class="rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-900 p-8 shadow-sm">
      <h2 class="text-2xl font-bold mb-4 dark:text-white">Datos institucionales</h2>
      <ul class="space-y-2 text-gray-700 dark:text-slate-300">
        <li><strong>Nombre:</strong> Asociación Civil "Hablemos de..." Defender la Vida</li>
        <li><strong>Naturaleza:</strong> ONG sin fines de lucro conformada por voluntarios</li>
        <li><strong>Presidenta:</strong> María Rosa Vargas</li>
        <li><strong>Inicios:</strong> 2004 · Personería Jurídica desde 2005</li>
        <li><strong>Personería Jurídica:</strong> Nº A-2839</li>
        <li><strong>Entidad de Bien Público:</strong> N°409</li>
        <li><strong>CUIT:</strong> 30-70972472-6</li>
        <li><strong>Sede:</strong> Posadas, Misiones, Argentina</li>
      </ul>
    </div>
  </section>

  <!-- CTA ******************* -->
  <CallToAction
    actions={[
      { variant: 'primary', text: 'Conocé qué hacemos', href: '/que-hacemos', icon: 'tabler:arrow-right' },
      { text: 'Contactanos', href: '/contacto', icon: 'tabler:mail' },
    ]}
  >
    <Fragment slot="title">Sumate a defender la vida</Fragment>
    <Fragment slot="subtitle">Tu participación hace la diferencia.</Fragment>
  </CallToAction>
</Layout>
