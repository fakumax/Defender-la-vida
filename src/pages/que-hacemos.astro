---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import foto2 from '~/data/2.jpg';
import foto3 from '~/data/3.jpg';
import foto5 from '~/data/5.jpg';

const metadata = {
  title: 'Qué hacemos',
};
---

<Layout metadata={metadata}>
  <!-- Hero ******************* -->
  <HeroText
    tagline="Qué hacemos"
    title="Prevención, contención y posvención"
    subtitle="Tres ejes de trabajo que abordan el suicidio desde una mirada comunitaria e integral, junto a escuelas, familias y equipos de salud."
  />

  <!-- Prevención ******************* -->
  <Content
    id="prevencion"
    isReversed
    tagline="Prevención"
    title="Talleres en escuelas y organizaciones"
    items={[
      {
        title: 'Adolescentes y jóvenes',
        description: 'Encuentros participativos para hablar de emociones, vínculos y búsqueda de ayuda.',
        icon: 'tabler:user-heart',
      },
      {
        title: 'Docentes y referentes',
        description: 'Capacitación para identificar signos de alerta y actuar a tiempo.',
        icon: 'tabler:school',
      },
      {
        title: 'Familias',
        description: 'Espacios para acompañar a madres, padres y cuidadores en la escucha y el diálogo.',
        icon: 'tabler:home-heart',
      },
    ]}
    image={{
      src: foto5,
      alt: 'Hablemos de lo que sentimos — taller en escuela',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Actuar antes</h3>
      <p>Charlas, talleres, capacitaciones y campañas para detectar a tiempo y promover factores protectores.</p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Orientación ******************* -->
  <Content
    id="orientacion"
    isAfterContent
    tagline="Contención"
    title="Orientación y contención"
    items={[
      {
        title: 'Escucha sin juicios',
        description: 'Un espacio seguro para quienes atraviesan una crisis o acompañan a alguien que la atraviesa.',
      },
      {
        title: 'Derivaciones responsables',
        description: 'Articulamos con equipos de salud mental, escuelas y organismos públicos.',
      },
      {
        title: 'Acompañamiento sostenido',
        description: 'No es una consulta única: hacemos seguimiento y acompañamos el proceso.',
      },
    ]}
    image={{
      src: foto2,
      alt: '¿Cómo cuidar en estos momentos? — Defender la Vida',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Acompañar el camino</h3>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Posvención ******************* -->
  <Content
    id="postvencion"
    isReversed
    isAfterContent
    tagline="Posvención"
    title="Posvención"
    items={[
      {
        title: 'Sostén entre pares',
        description: 'Reuniones periódicas donde compartir la experiencia del duelo sin sentirse solo/a.',
        icon: 'tabler:users',
      },
      {
        title: 'Coordinación profesional',
        description: 'Los encuentros son guiados por profesionales formados/as en duelo por suicidio.',
        icon: 'tabler:heart-rate-monitor',
      },
      {
        title: 'Confidencialidad',
        description: 'Lo que se comparte en el grupo se cuida con respeto y reserva absoluta.',
        icon: 'tabler:lock',
      },
    ]}
    image={{
      src: foto3,
      alt: 'Cada vida es valiosa — Defender la Vida',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Acompañar en el duelo
      </h3>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- CTA ******************* -->
  <CallToAction
    actions={[
        { variant: 'primary', text: 'Solicitar una actividad', href: 'https://api.whatsapp.com/send/?phone=5493764385252&text=Hola%2C+me+comunico+desde+la+web+de+Defender+la+Vida.&type=phone_number&app_absent=0', icon: 'tabler:calendar-plus' },
      { text: 'Conocé la asociación', href: '/quienes-somos', icon: 'tabler:users' },
    ]}
  >
    <Fragment slot="title">¿Querés que llevemos un taller a tu institución?</Fragment>
    <Fragment slot="subtitle">Trabajamos en Posadas, Misiones y toda la región.</Fragment>
  </CallToAction>
</Layout>
