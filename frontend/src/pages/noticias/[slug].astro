---
import Layout from '~/layouts/PageLayout.astro';
import { getPosts } from '~/lib/wp';

export async function getStaticPaths() {
    const posts = await getPosts(100);
    
    if (!posts || posts.length === 0) {
        return [{ params: { slug: 'placeholder' }, props: { post: { title: { rendered: 'Contenido Temporal' }, content: { rendered: '<p>Abrí WordPress y cargá tu primera noticia.</p>' }, excerpt: { rendered: '' }, _embedded: {} } } }];
    }

    return posts.map((post: any) => ({
        params: { slug: post.slug },
        props: { post },
    }));
}

const { post } = Astro.props;

const metadata = {
  title: post.title.rendered.replace(/<[^>]*>/g, ''),
};
---

<Layout metadata={metadata}>
  <article class="px-4 py-16 sm:px-6 mx-auto lg:px-8 max-w-4xl">
    <a href="/noticias" class="text-primary font-semibold hover:underline mb-8 inline-block">← Volver a Noticias</a>
    
    <h1 class="text-4xl md:text-5xl font-bold leading-tighter tracking-tighter mb-8 font-heading dark:text-gray-200" set:html={post.title.rendered} />

    {post._embedded?.['wp:featuredmedia']?.[0]?.source_url && (
      <img
        src={post._embedded['wp:featuredmedia'][0].source_url}
        alt={post.title.rendered.replace(/<[^>]*>/g, '')}
        class="w-full h-[400px] object-cover rounded-xl shadow-lg mb-12"
        loading="lazy"
      />
    )}

    <div class="prose prose-lg md:prose-xl dark:prose-invert max-w-none prose-a:text-primary hover:prose-a:underline prose-headings:font-heading prose-img:rounded-xl" set:html={post.content.rendered} />
  </article>
</Layout>
