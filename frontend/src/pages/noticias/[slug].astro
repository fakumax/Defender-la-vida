---
import Layout from '~/layouts/PageLayout.astro';
import SinglePost from '~/components/blog/SinglePost.astro';
import ToBlogLink from '~/components/blog/ToBlogLink.astro';
import { getPosts } from '~/lib/wp';
import type { Post } from '~/types';

export async function getStaticPaths() {
  const wpPosts = await getPosts(100);

  if (!wpPosts || wpPosts.length === 0) {
    return [{
      params: { slug: 'placeholder' },
      props: {
        post: {
          id: '0', slug: 'placeholder', permalink: '/noticias/placeholder',
          publishDate: new Date(), title: 'Contenido Temporal',
          excerpt: '', content: '<p>Abrí WordPress y cargá tu primera noticia.</p>',
        } as Post,
      },
    }];
  }

  return wpPosts.map((p: any) => ({
    params: { slug: p.slug },
    props: {
      post: {
        id: String(p.id),
        slug: p.slug,
        permalink: `/noticias/${p.slug}`,
        publishDate: new Date(p.date),
        title: p.title?.rendered?.replace(/<[^>]*>/g, '') ?? '',
        excerpt: p.excerpt?.rendered?.replace(/<[^>]*>/g, '').trim() ?? '',
        image: p._embedded?.['wp:featuredmedia']?.[0]?.source_url ?? undefined,
        author: p._embedded?.['author']?.[0]?.name ?? undefined,
        content: p.content?.rendered ?? '',
      } as Post,
    },
  }));
}

const { post } = Astro.props as { post: Post };

const metadata = {
  title: post.title,
  description: post.excerpt,
};
---

<Layout metadata={metadata}>
  <SinglePost post={post} url={`/noticias/${post.slug}`}>
    <Fragment set:html={post.content ?? ''} />
  </SinglePost>
  <ToBlogLink />
</Layout>
