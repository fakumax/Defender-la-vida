---
import Layout from '~/layouts/PageLayout.astro';
import BlogList from '~/components/blog/List.astro';
import Headline from '~/components/blog/Headline.astro';
import { getPosts } from '~/lib/wp';
import type { Post } from '~/types';

const metadata = {
  title: 'Noticias',
  description: 'Últimas noticias de la Asociación Hablemos de Defender la Vida.',
};

const wpPosts = await getPosts();

const posts: Post[] = (wpPosts ?? []).map((p: any) => ({
  id: String(p.id),
  slug: p.slug,
  permalink: `/noticias/${p.slug}`,
  publishDate: new Date(p.date),
  title: p.title?.rendered?.replace(/<[^>]*>/g, '') ?? '',
  excerpt: p.excerpt?.rendered?.replace(/<[^>]*>/g, '').trim() ?? '',
  image: p._embedded?.['wp:featuredmedia']?.[0]?.source_url ?? undefined,
  author: p._embedded?.['author']?.[0]?.name ?? undefined,
  content: p.content?.rendered ?? '',
}));
---

<Layout metadata={metadata}>
  <section class="px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <Headline subtitle="Novedades y talleres de nuestra asociación.">
      Noticias
    </Headline>
    {posts.length > 0 ? (
      <BlogList posts={posts} />
    ) : (
      <div class="text-center p-12 text-muted">
        <p>No hay noticias publicadas en este momento.</p>
      </div>
    )}
  </section>
</Layout>
