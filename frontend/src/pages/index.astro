---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import NoticiasLatestPosts from '~/components/widgets/NoticiasLatestPosts.astro';
import HeroCarousel from '~/components/common/HeroCarousel.astro';
import { getHeroSlides } from '~/lib/wp';
import imagen1 from '~/assets/images/Imagen1.png';
import imagen2 from '~/assets/images/Imagen2.png';

const wpSlides = await getHeroSlides();

const slides = wpSlides.length
  ? wpSlides
  : [
      { image: imagen1.src, alt: 'Defender la Vida — prevención y acompañamiento' },
      { image: imagen2.src, alt: 'Comunidad que cuida — Defender la Vida' },
    ];

const metadata = {
  title: 'Hablemos de Defender la Vida — Prevención del suicidio en Posadas, Misiones',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero ******************* -->
  <Hero
    actions={[
      { variant: 'primary', text: 'Pedir ayuda', href: '/contacto', icon: 'tabler:heart-handshake' },
      { text: 'Conocé nuestro trabajo', href: '/quienes-somos' },
    ]}
  >
    <Fragment slot="title">
      Hablemos de <span class="text-accent dark:text-white">Defender la Vida</span>
    </Fragment>

    <Fragment slot="subtitle">
      Asociación Civil dedicada a la <strong>prevención, contención y posvención</strong> del suicidio
      en adolescentes y jóvenes. Acompañamos a quienes atraviesan situaciones de riesgo y a sus familias.
      <span class="block mt-2 font-semibold text-red-600">
        Si estás pasando un momento difícil, llamá al 135 (línea gratuita) o al 911.
      </span>
    </Fragment>

    <Fragment slot="image">
      <HeroCarousel slides={slides} autoplay={6000} />
    </Fragment>
  </Hero>

  <!-- Nota ******************* -->
  <Note title="Nuestra misión:" description="Prevenir el suicidio y promover una cultura de cuidado colectivo." />

  <!-- Quiénes somos — resumen ******************* -->
  <Content
    id="quienes-somos"
    tagline="Quiénes somos"
    title="Una asociación que nació para cuidar la vida"
    items={[
      {
        title: 'Prevención',
        description: 'Trabajamos con escuelas, familias y comunidades para detectar signos de alerta a tiempo.',
        icon: 'tabler:shield-heart',
      },
      {
        title: 'Contención',
        description: 'Acompañamos a jóvenes en situación de riesgo y a su entorno familiar y social.',
        icon: 'tabler:users',
      },
      {
        title: 'Posvención',
        description: 'Brindamos apoyo a familias y comunidades que atravesaron la pérdida de un ser querido.',
        icon: 'tabler:heart-handshake',
      },
    ]}
    image={{
      src: '~/assets/images/Imagen2.png',
      alt: 'Comunidad que cuida — Defender la Vida',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        "Defender la Vida" nace en Posadas, Misiones
      </h3>
      <p>
        Con el firme propósito de prevenir el suicidio en adolescentes y jóvenes. Creemos que la prevención
        es posible y eficaz cuando nos involucramos todos: familia, escuela, trabajo y comunidad.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Qué hacemos — features ******************* -->
  <Features
    id="que-hacemos"
    tagline="Qué hacemos"
    title="Nuestros pilares de trabajo"
    subtitle="Intervenciones integrales para transformar actitudes violentas mediante la convivencia, la resolución de conflictos y el respeto mutuo."
    items={[
      {
        title: 'Talleres de prevención',
        description: 'Actividades en escuelas, clubes y organizaciones de Posadas y la provincia.',
        icon: 'tabler:presentation',
      },
      {
        title: 'Orientación',
        description: 'Espacio de escucha y derivación para jóvenes, familias y docentes.',
        icon: 'tabler:message-circle',
      },
      {
        title: 'Grupos GARE',
        description: 'Grupos de Ayuda para familiares y allegados en duelo por suicidio.',
        icon: 'tabler:users-group',
      },
      {
        title: 'Capacitaciones',
        description: 'Formación para equipos de salud, educación y comunidades.',
        icon: 'tabler:school',
      },
      {
        title: 'Campañas de concientización',
        description: 'Promovemos el diálogo y el cuidado de la salud mental en toda la región.',
        icon: 'tabler:speakerphone',
      },
      {
        title: 'Red de acompañamiento',
        description: 'Articulación con instituciones públicas, privadas y de la sociedad civil.',
        icon: 'tabler:network',
      },
    ]}
  />

  <!-- Estadísticas ******************* -->
  <Stats
    title="20+ años defendiendo la vida"
    subtitle="Desde Posadas, Misiones, para toda la región."
    stats={[
      { title: 'Años de trabajo', amount: '20+' },
      { title: 'Talleres anuales', amount: '50+' },
      { title: 'Jóvenes alcanzados', amount: '5k+' },
      { title: 'Familias acompañadas', amount: '500+' },
    ]}
  />

  <!-- Últimas noticias del blog ******************* -->
  <NoticiasLatestPosts
    id="publicaciones"
    title="Últimas publicaciones"
    information={`Artículos, reflexiones y materiales de nuestro equipo. También podés visitar la sección de Noticias para ver los talleres y acciones más recientes.`}
  />

  <!-- Call to action ******************* -->
  <CallToAction
    actions={[
      { variant: 'primary', text: 'Contactanos', href: '/contacto', icon: 'tabler:mail' },
      { text: 'Línea 135', href: 'tel:135', icon: 'tabler:phone' },
    ]}
  >
    <Fragment slot="title">¿Necesitás hablar con alguien?</Fragment>
    <Fragment slot="subtitle">
      No estás solo/a. Escribinos o llamá a la línea gratuita de prevención <strong>135</strong>.
    </Fragment>
  </CallToAction>
</Layout>
