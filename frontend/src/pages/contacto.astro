---
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';

const metadata = {
  title: 'Contacto',
};

const channels = [
  {
    title: 'WhatsApp',
    value: '+54 9 3764 38-5252',
    href: 'https://wa.me/5493764385252',
    icon: 'tabler:brand-whatsapp',
  },
  {
    title: 'Email',
    value: 'defenderlavida@gmail.com',
    href: 'mailto:defenderlavida@gmail.com',
    icon: 'tabler:mail',
  },
  {
    title: 'Instagram',
    value: '@asocdefenderlavida',
    href: 'https://www.instagram.com/asocdefenderlavida/',
    icon: 'tabler:brand-instagram',
  },
  {
    title: 'Facebook',
    value: 'AsocDefenderLaVida',
    href: 'https://www.facebook.com/AsocDefenderLaVida/',
    icon: 'tabler:brand-facebook',
  },
  {
    title: 'Línea 135',
    value: 'Asistencia al suicida · 24 hs',
    href: 'tel:135',
    icon: 'tabler:phone',
  },
  {
    title: 'Ubicación',
    value: 'Posadas, Misiones, Argentina',
    icon: 'tabler:map-pin',
  },
];
---

<Layout metadata={metadata}>
  <!-- Aviso emergencia ******************* -->
  <section class="bg-red-600 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex flex-col sm:flex-row items-center justify-center gap-3 text-center">
      <span class="font-semibold">¿Necesitás ayuda urgente?</span>
      <a href="tel:135" class="underline font-bold">Llamá al 135 (Prevención)</a>
      <span class="hidden sm:inline">·</span>
      <a href="tel:911" class="underline font-bold">o al 911 (Emergencias)</a>
    </div>
  </section>

  <!-- Hero ******************* -->
  <HeroText
    tagline="Contacto"
    title="Hablemos"
    subtitle="Si querés organizar un taller, sumarte como voluntario/a, o simplemente necesitás hablar con alguien, escribinos. Te respondemos lo antes posible."
  />

  <!-- Formulario ******************* -->
  <ContactUs
    id="form"
    title="Escribinos un mensaje"
    subtitle="Completá el formulario y nos pondremos en contacto a la brevedad."
    inputs={[
      { type: 'text', name: 'name', label: 'Nombre y apellido' },
      { type: 'email', name: 'email', label: 'Correo electrónico' },
      { type: 'text', name: 'phone', label: 'Teléfono (opcional)' },
      { type: 'text', name: 'subject', label: 'Asunto' },
    ]}
    textarea={{ label: 'Tu mensaje' }}
    disclaimer={{
      label:
        'Al enviar este formulario, aceptás que tus datos sean utilizados únicamente para responder a tu consulta.',
    }}
    description="Respondemos habitualmente dentro de las 48 horas hábiles."
  />

  <!-- Redes y datos ******************* -->
  <section class="px-4 sm:px-6 mx-auto lg:px-8 max-w-5xl py-8 md:py-12">
    <div class="text-center mb-6">
      <h2 class="text-2xl md:text-3xl font-bold font-heading text-heading">Otros canales</h2>
      <p class="text-muted mt-2">También podés encontrarnos acá.</p>
    </div>
    <ul class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
      {channels.map(({ title, value, href, icon }) => {
        const Tag = href ? 'a' : 'div';
        return (
          <li>
            <Tag
              {...(href ? { href, target: href.startsWith('http') ? '_blank' : undefined, rel: href.startsWith('http') ? 'noopener noreferrer' : undefined } : {})}
              class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-900 hover:border-primary hover:shadow-sm transition"
            >
              <Icon name={icon} class="w-5 h-5 text-primary flex-shrink-0" />
              <span class="flex flex-col leading-tight">
                <span class="text-sm font-semibold text-gray-900 dark:text-slate-100">{title}</span>
                <span class="text-xs text-gray-600 dark:text-slate-400 break-all">{value}</span>
              </span>
            </Tag>
          </li>
        );
      })}
    </ul>
  </section>

  <!-- Datos legales ******************* -->
  <section class="px-4 py-12 sm:px-6 mx-auto lg:px-8 max-w-4xl">
    <div class="rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-900 p-6 text-sm text-gray-600 dark:text-slate-400 text-center">
      <p class="font-semibold text-gray-800 dark:text-slate-200 mb-1">
        Asociación Civil "Hablemos de Defender la Vida"
      </p>
      <p>
        Personería Jurídica Nº A-2839 · Entidad de Bien Público N°409 · CUIT 30-70972472-6
      </p>
      <p>Posadas — Misiones — Argentina</p>
    </div>
  </section>
</Layout>
