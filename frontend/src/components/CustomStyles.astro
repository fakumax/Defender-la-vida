---
import '@fontsource/libre-baskerville/400.css';
import '@fontsource/libre-baskerville/700.css';
import '@fontsource/libre-baskerville/400-italic.css';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Libre Baskerville';
    --aw-font-serif: 'Libre Baskerville';
    --aw-font-heading: 'Libre Baskerville';

    --aw-color-primary: #008181;
    --aw-color-secondary: #006666;
    --aw-color-accent: #DE7523;

    --aw-color-text-heading: rgb(0 0 0);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(3 6 32);

    ::selection {
      background-color: #F0E51E;
    }
  }

  .dark {
    --aw-font-sans: 'Libre Baskerville';
    --aw-font-serif: 'Libre Baskerville';
    --aw-font-heading: 'Libre Baskerville';

    --aw-color-primary: #00A3A3;
    --aw-color-secondary: #008181;
    --aw-color-accent: #F0E51E;

    --aw-color-text-heading: rgb(247, 248, 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(3 6 32);

    ::selection {
      background-color: #DE7523;
      color: snow;
    }
  }
</style>
